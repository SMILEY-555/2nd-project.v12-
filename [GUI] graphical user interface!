# ====================== DATA CLASSES ======================
@dataclass
class ScriptMetadata:
    name: str
    author: str = "Unknown"
    version: str = "1.0"
    hash: str = ""
    size: int = 0
    is_malicious: bool = False

@dataclass
class ExecutorConfig:
    name: str
    version: str
    supported_anti_cheats: List[str] = field(default_factory=list)
    ui_theme: str = "Dark"
    auto_attach: bool = True
    bypass_level: int = 3
    max_threads: int = 8

# ====================== DECORATORS ======================
def log_execution(func):
    @functools.wraps(func)
    def wrapper(self, *args, **kwargs):
        print(f"[{self.name}] Executing {func.__name__}()")
        start = time.time()
        result = func(self, *args, **kwargs)
        print(f"[{self.name}] {func.__name__} completed in {time.time()-start:.4f}s")
        return result
    return wrapper

# ====================== BASE EXECUTOR ======================
class BaseExecutor:
    def __init__(self, config: ExecutorConfig):
        self.config = config
        self.state = ExecutionState.IDLE
        self.script_queue: queue.Queue = queue.Queue()
        self.log_buffer: List[str] = []
        self.attached = False
        self._lock = threading.Lock()
        self.console_output = []

    def log(self, message: str, level: str = "INFO"):
        timestamp = time.strftime("%H:%M:%S")
        entry = f"[{timestamp}][{level}] {message}"
        with self._lock:
            self.log_buffer.append(entry)
            self.console_output.append(entry)
        print(entry)

    @log_execution
    def inject(self) -> bool:
        self.state = ExecutionState.INJECTING
        self.log("Starting injection process...", "DEBUG")
        time.sleep(0.8)  # Simulate delay
        
        for i in range(5):
            progress = (i+1) * 20
            self.log(f"Injection progress: {progress}%", "DEBUG")
            time.sleep(0.3)
        
        self.attached = True
        self.state = ExecutionState.ATTACHED
        self.log(f"{self.config.name} successfully attached to Roblox!", "SUCCESS")
        return True

    @log_execution
    def execute(self, script: str, metadata: Optional[ScriptMetadata] = None) -> bool:
        if not self.attached:
            self.log("Cannot execute: Not attached!", "ERROR")
            return False
        
        self.state = ExecutionState.EXECUTING
        self.log(f"Executing script: {metadata.name if metadata else 'Untitled'}")
        
        # Simulate Lua sandbox execution
        try:
            # Fake Lua parsing
            if "print" in script:
                output = script.split("print(")[1].split(")")[0].strip('"\'')
                self.console_output.append(f"[Roblox] {output}")
            
            time.sleep(random.uniform(0.1, 0.6))
            self.log("Script executed successfully!", "SUCCESS")
            return True
        except Exception as e:
            self.log(f"Execution error: {e}", "ERROR")
            self.state = ExecutionState.ERROR
            return False
        finally:
            self.state = ExecutionState.ATTACHED

    def get_console(self) -> List[str]:
        return self.console_output[-50:]  # last 50 lines

