# ====================== EXECUTOR MANAGER ======================
class ExecutorManager:
    def __init__(self):
        self.executors: Dict[str, BaseExecutor] = {}
        self.current_executor: Optional[BaseExecutor] = None
        self.register_all()

    def register_all(self):
        self.executors["delta"] = DeltaExecutor()
        self.executors["fluxus"] = FluxusExecutor()
        self.executors["solara"] = SolaraExecutor()
        self.executors["wave"] = BaseExecutor(ExecutorConfig("Wave", "1.0"))
        self.executors["codex"] = BaseExecutor(ExecutorConfig("Codex", "3.2"))
        print("✅ All executors registered")

    def switch_executor(self, name: str) -> bool:
        if name.lower() in self.executors:
            self.current_executor = self.executors[name.lower()]
            print(f"Switched to {self.current_executor.config.name}")
            return True
        return False

    def inject_current(self):
        if self.current_executor:
            return self.current_executor.inject()
        return False

    def execute_script(self, script: str, name: str = "Untitled.lua"):
        if not self.current_executor:
            print("No executor selected!")
            return False
        
        metadata = ScriptMetadata(
            name=name,
            hash=hashlib.md5(script.encode()).hexdigest()[:8]
        )
        return self.current_executor.execute(script, metadata)

